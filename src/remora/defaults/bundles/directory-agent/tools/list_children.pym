# List all child nodes (functions, classes, subdirectories) in this directory.
from grail import external


@external
async def graph_get_children(parent_id: str | None = None) -> list[dict]: ...


children = await graph_get_children()
if not children:
    result = "No children found."
else:
    lines = [
        f"- [{child.get('node_type', '?')}] {child.get('name', '?')} ({child.get('node_id', '?')})"
        for child in children
    ]
    result = "Children:\n" + "\n".join(lines)
result
