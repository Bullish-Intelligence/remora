# Remove a subscription from this agent.
from grail import Input, external

subscription_id: int = Input("subscription_id")


@external
async def event_unsubscribe(subscription_id: int) -> bool: ...


result = await event_unsubscribe(subscription_id)
if result:
    message = f"Unsubscribed: {subscription_id}"
else:
    message = f"Subscription not found: {subscription_id}"
message
