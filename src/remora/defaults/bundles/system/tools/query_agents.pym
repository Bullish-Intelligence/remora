# Query the node graph for agents with optional filters.
from grail import Input, external

node_type: str = Input("node_type", default="")
role: str = Input("role", default="")
status: str = Input("status", default="")
file_path: str = Input("file_path", default="")


@external
async def graph_query_nodes(
    node_type: str | None,
    status: str | None,
    file_path: str | None = None,
    role: str | None = None,
) -> list[dict]: ...


node_type_value: str | None = node_type.strip() if node_type.strip() else None
role_value: str | None = role.strip() if role.strip() else None
status_value: str | None = status.strip() if status.strip() else None
file_path_value: str | None = file_path.strip() if file_path.strip() else None

agents = await graph_query_nodes(
    node_type_value,
    status_value,
    file_path_value,
    role_value,
)
result = str(agents)
result
